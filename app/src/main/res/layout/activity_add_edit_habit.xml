<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/textViewAddHabitTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_bold"
        android:text="New Habit"
        android:textColor="#1B4332"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/edtHabitTitle"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins_regular"
        android:hint="Habit Title"
        android:paddingStart="20dp"
        android:textColor="#1B4332"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/textViewAddHabitTitle" />

    <EditText
        android:id="@+id/edtHabitDescription"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins_regular"
        android:gravity="top"
        android:hint="Description (optional)"
        android:padding="20dp"
        android:textColor="#1B4332"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/edtHabitTitle" />

    <Button
        android:id="@+id/btnSaveHabit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#2D6A4F"
        android:text="Save Habit"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/edtHabitDescription"
        android:fontFamily="@font/poppins_bold" />

</androidx.constraintlayout.widget.ConstraintLayout>
