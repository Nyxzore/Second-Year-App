<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    tools:context=".AddEditHabit">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->

        <TextView
            android:id="@+id/textViewAddHabitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_bold"
            android:text="New Habit"
            android:textColor="#1B4332"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/textViewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/poppins_regular"
            android:text="Build habits, achieve your goals."
            android:textColor="#6B7C6F"
            android:textSize="15sp" />

        <!-- MAIN CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HABIT NAME -->

            <TextView
                android:id="@+id/txtHabitName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Habit Name"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edtHabitTitle"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/poppins_regular"
                android:hint="e.g. Drink Water"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1B4332"
                android:textColorHint="#9AA5A0"
                android:textSize="14sp" />

            <!-- DESCRIPTION -->

            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Description"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edtHabitDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/poppins_regular"
                android:gravity="top"
                android:hint="Why is this habit important?"
                android:padding="16dp"
                android:textColor="#1B4332"
                android:textColorHint="#9AA5A0"
                android:textSize="14sp" />

            <!-- CATEGORY -->

            <TextView
                android:id="@+id/txtCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Category"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- HEALTH -->

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/category_selected"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="#2D6A4F" />

                        <TextView
                            android:id="@+id/txtHealth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_medium"
                            android:text="Health"
                            android:textColor="#2D6A4F"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- PRODUCTIVITY -->

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/card_bg"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="#7A8C7F" />

                        <TextView
                            android:id="@+id/txtProductivity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_medium"
                            android:text="Productivity"
                            android:textColor="#7A8C7F"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- LIFESTYLE -->

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="110dp"
                        android:background="@drawable/card_bg"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#7A8C7F" />

                        <TextView
                            android:id="@+id/txtLifestyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_medium"
                            android:text="Lifestyle"
                            android:textColor="#7A8C7F"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- FREQUENCY -->

            <TextView
                android:id="@+id/txtFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Frequency"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/spinnerFrequency"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:padding="10dp" />

            <!-- REMINDER -->

            <TextView
                android:id="@+id/txtReminderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Reminder Time"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edtReminderTime"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/poppins_regular"
                android:hint="Pick a time"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1B4332"
                android:textColorHint="#9AA5A0"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- SAVE BUTTON -->

        <Button
            android:id="@+id/btnSaveHabit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="30dp"
            android:backgroundTint="#2D6A4F"
            android:fontFamily="@font/poppins_bold"
            android:text="Save Habit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

</ScrollView>

