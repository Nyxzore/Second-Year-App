<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FBF6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/poppins_bold"
            android:text="Add Goal"
            android:textColor="#1E1B39"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="30dp"
            android:fontFamily="@font/poppins_light_italic"
            android:text="Create a goal that matters to you"
            android:textColor="#7E7E93"
            android:textSize="15sp" />

        <!-- GOAL TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal Title"
            android:textColor="#1E1B39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_regular"/>

        <EditText
            android:id="@+id/edtGoalTitle"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. Run 5KM in under 30 minutes"
            android:padding="15dp"
            android:textColor="#1E1B39"
            android:textColorHint="#A0A0B2"
            android:textSize="16sp"
            android:textCursorDrawable="@null"
            android:fontFamily="@font/poppins_extra_light"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="Give your goal a clear and motivating title."
            android:textColor="#8E8EA0"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"/>

        <!-- CATEGORY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textColor="#1E1B39"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:id="@+id/btnAddCategoryGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" + Add New"
                android:textColor="#3CB371"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold"
                android:padding="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtGoalCategoryHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Select one or more. Add categories from the goals list (+)."
            android:textColor="#8E8EA0"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupGoalCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp" />

        <!-- TARGET DATE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Target Date"
            android:textColor="#1E1B39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_regular"/>
        <TextView
            android:id="@+id/lblDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="yyyy/mm//dd"
            android:textColor="#1E1B39"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_regular"/>
        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/edittext_background"
            android:fontFamily="@font/poppins_light" />

        <!-- DESCRIPTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Notes"
            android:textColor="#1E1B39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_regular"/>

        <EditText
            android:id="@+id/edtGoalDescription"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/edittext_background"
            android:gravity="top"
            android:hint="Why is this goal important to you?"
            android:inputType="textMultiLine"
            android:padding="15dp"
            android:textColor="#1E1B39"
            android:textColorHint="#A0A0B2"
            android:textSize="15sp"
            android:textCursorDrawable="@null"
            android:fontFamily="@font/poppins_extra_light"
            />

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnAdd"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="40dp"
            android:backgroundTint="#3CB371"
            android:text="CREATE GOAL"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"/>

    </LinearLayout>

</ScrollView>