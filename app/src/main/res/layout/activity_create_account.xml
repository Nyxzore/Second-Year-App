<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FBF4"
    android:padding="24dp"
    tools:context=".CreateAccount">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/txtLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Logo -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />
            <!-- Title -->
            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Welcome"
                android:textColor="#1B4332"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/textViewSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_regular"
                android:text="Create your account to get started"
                android:textColor="#52796F"
                android:textSize="14sp" />

            <!-- Username -->
            <EditText
                android:id="@+id/edtCreateUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/poppins_extra_light"
                android:hint="Full Name"
                android:textColorHint="#84A98C"
                android:paddingStart="20dp"
                android:textColor="#1B4332"
                android:textSize="16sp" />

            <!-- Email -->
            <EditText
                android:id="@+id/edtCreateEmail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Email Address"
                android:textColorHint="#84A98C"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:textColor="#1B4332"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_extra_light"/>

            <!-- Password -->
            <EditText
                android:id="@+id/edtCreatePassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Password"
                android:textColorHint="#84A98C"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:textColor="#1B4332"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_extra_light"/>

            <!-- Confirm Password -->
            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Confirm Password"
                android:textColorHint="#84A98C"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:textColor="#1B4332"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_extra_light"/>

            <!-- Admin Checkbox -->
            <CheckBox
                android:id="@+id/chk_idAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Register as Admin"
                android:textColor="#1B4332"
                android:fontFamily="@font/poppins_regular" />

            <!-- Create Account Button -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#2D6A4F"
                android:onClick="handleRegister"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                android:fontFamily="@font/poppins_bold"/>

            <!-- Status Text -->
            <TextView
                android:id="@+id/textViewStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:textColor="#D00000"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Login Link -->
    <TextView
        android:id="@+id/txtLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Already have an account? Log in"
        android:textColor="#40916C"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:fontFamily="@font/poppins_regular"/>

</androidx.constraintlayout.widget.ConstraintLayout>